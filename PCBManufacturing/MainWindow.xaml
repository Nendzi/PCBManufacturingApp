<Window x:Class="PCBManufacturing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCBManufacturing"
				xmlns:userctrl="clr-namespace:PCBManufacturing.Controls"
				xmlns:conv ="clr-namespace:PCBManufacturing.Converters"
				xmlns:val ="clr-namespace:PCBManufacturing.Validators"
        mc:Ignorable="d"
        Title="PCB Manufacturing"
				Height="550" Width="500"
				MinHeight="550" MinWidth="500"
				ContentRendered="Window_ContentRendered">

	<Window.Resources>
		<conv:DoubleToVisibilityConverter x:Key="DoubleToVisibilityConverter"/>
		<conv:SelectedWidthToFontWeightConverter x:Key="SelectedWidthToFontWeightConverter"/>
	</Window.Resources>

	<Grid>
		<TabControl>
			<TabItem Header="Preferences" Width="100" >
				<Grid >
					<Grid.RowDefinitions>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
					</Grid.RowDefinitions>

					<userctrl:DropdownListWithLabel
						Grid.Row="0"
						LabelText="{Binding MaterialPreference.Label}"
						Items="{Binding MaterialPreference.Options}"
						SelectedItem="{Binding MaterialPreference.SelectedOption}"
						ShowColorSquares="{Binding MaterialPreference.ShowColorSquares}"/>
					<userctrl:DropdownListWithLabel
						Grid.Row="1"
						LabelText="{Binding SolderMaskPreferences.Label}"
						Items="{Binding SolderMaskPreferences.Options}"
						SelectedItem="{Binding SolderMaskPreferences.SelectedOption}"
						ShowColorSquares="{Binding SolderMaskPreferences.ShowColorSquares}"/>
					<userctrl:DropdownListWithLabel
						Grid.Row="2"
						LabelText="{Binding ThicknessPreference.Label}"
						Items="{Binding ThicknessPreference.Options}"
						SelectedItem="{Binding ThicknessPreference.SelectedOption}"
						ShowColorSquares="{Binding ThicknessPreference.ShowColorSquares}"/>

					<StackPanel Grid.Row="3" 
					Visibility="{Binding PriceDayQty, Converter={StaticResource DoubleToVisibilityConverter}}">
						<Label Content="Your selection has influence on price and delivery time"/>
						<UniformGrid Columns="2" Rows="1">
							<Label Content="{Binding PriceIncreasing}"/>
							<Label Content="{Binding DeliveryTimeExtended}"/>
						</UniformGrid>
					</StackPanel>

					<StackPanel Grid.Row="4" Orientation="Horizontal">
						<Label Content="Please enter postcode"/>
						<TextBox
						x:Name="PostalCodeTextBox"
						Width="120"
						TextAlignment="Center"
						Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged,ValidatesOnNotifyDataErrors=True}">
							<TextBox.Style>
								<Style TargetType="TextBox">
									<!-- Default (valid) state -->
									<Setter Property="BorderBrush" Value="Green"/>
									<Setter Property="BorderThickness" Value="1"/>
									<Setter Property="FontSize" Value="16"/>
									<!-- Invalid state trigger -->
									<Style.Triggers>
										<Trigger Property="Validation.HasError" Value="True">
											<Setter Property="BorderBrush" Value="Red"/>
											<Setter Property="BorderThickness" Value="2"/>
											<Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self},Path=(Validation.Errors)[0].ErrorContent}"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</TextBox.Style>														
						</TextBox>
						<TextBlock
                   Foreground="Red" 
                   FontSize="12"
                   Margin="5,0,0,0"
                   MinHeight="20"
									 MaxWidth="250"
									 TextWrapping="Wrap">
							<TextBlock.Text>
								<Binding ElementName="PostalCodeTextBox" Path="(Validation.Errors)[0].ErrorContent"/>
							</TextBlock.Text>
						</TextBlock>

						<!-- Show valid state indicator -->
						<TextBlock
                   Foreground="Green" 
                   FontSize="12"
                   Margin="0,5,0,0">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Text" Value="✓ Valid postal code"/>
									<Setter Property="Visibility" Value="Collapsed"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding ElementName=PostalCodeTextBox, Path=(Validation.HasError)}" Value="False">
											<Setter Property="Visibility" Value="Visible"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</StackPanel>
				</Grid>
			</TabItem>
			<TabItem Header="Quote" Width="100"  >
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*"/>
						<ColumnDefinition Width="3*"/>
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<Expander IsExpanded="True"
    ExpandDirection="Down"
    Background="#FAFAFA"
    BorderBrush="#D0D7DE"
    BorderThickness="1"
    Padding="2"
    Foreground="#1F2937"
    FontSize="14"
    FontWeight="SemiBold" Grid.Column="0" Grid.Row="0">
						<Expander.Header>
							<DockPanel LastChildFill="True" Margin="2">
								<TextBlock
                Text="Width"
                FontSize="14"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />
							</DockPanel>
						</Expander.Header>
						<ItemsControl						
						Margin="10"
						ItemsSource="{Binding Widths}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="#D0D7DE" BorderThickness="1">
										<StackPanel Orientation="Horizontal">
											<TextBox
												Margin="5" BorderThickness="0"
												Text="{Binding Mode=OneWay}"
												IsReadOnly="True"												
												PreviewMouseLeftButtonUp="WidthTextBox_MouseLeftButtonUp">
												<TextBox.FontWeight>
													<MultiBinding Converter="{StaticResource SelectedWidthToFontWeightConverter}">
														<Binding />
														<Binding
															Path="DataContext.Width"
															RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
													</MultiBinding>
												</TextBox.FontWeight>
											</TextBox>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Expander>
					<Expander IsExpanded="False"
ExpandDirection="Down"
Background="#FAFAFA"
BorderBrush="#D0D7DE"
BorderThickness="1"
Padding="2"
Foreground="#1F2937"
FontSize="14"
FontWeight="SemiBold" Grid.Column="0" Grid.Row="1">
						<Expander.Header>
							<DockPanel LastChildFill="True" Margin="2">
								<TextBlock
            Text="Length"
            FontSize="14"
            FontWeight="SemiBold"
            VerticalAlignment="Center" />
							</DockPanel>
						</Expander.Header>
						<ItemsControl
					Margin="10"
						ItemsSource="{Binding Lenghts}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="#D0D7DE" BorderThickness="1">
										<StackPanel Orientation="Horizontal">
											<TextBox
										Margin="5" BorderThickness="0"
										Text="{Binding Mode=OneWay}"
										IsReadOnly="True"
										PreviewMouseLeftButtonUp="LenghtTextBox_MouseLeftButtonUp">
												<TextBox.FontWeight>
													<MultiBinding Converter="{StaticResource SelectedWidthToFontWeightConverter}">
														<Binding />
														<Binding
														Path="DataContext.Length"
														RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
													</MultiBinding>
												</TextBox.FontWeight>
											</TextBox>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Expander>
					<Expander IsExpanded="False"
ExpandDirection="Down"
Background="#FAFAFA"
BorderBrush="#D0D7DE"
BorderThickness="1"
Padding="2"
Foreground="#1F2937"
FontSize="14"
FontWeight="SemiBold" Grid.Column="0" Grid.Row="2">
						<Expander.Header>
							<DockPanel LastChildFill="True" Margin="2">
								<TextBlock
            Text="Number of layers"
            FontSize="14"
            FontWeight="SemiBold"
            VerticalAlignment="Center" />
							</DockPanel>
						</Expander.Header>
						<ItemsControl
						Margin="10"
						ItemsSource="{Binding LayersQtys}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border  BorderBrush="#D0D7DE" BorderThickness="1">
										<StackPanel Orientation="Horizontal">
											<TextBox
											Margin="5" BorderThickness="0"
											Text="{Binding Mode=OneWay}"
											IsReadOnly="True"
											PreviewMouseLeftButtonUp="LeyersQtyTextBox_MouseLeftButtonUp">
												<TextBox.FontWeight>
													<MultiBinding Converter="{StaticResource SelectedWidthToFontWeightConverter}">
														<Binding />
														<Binding
														Path="DataContext.LayerQty"
														RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
													</MultiBinding>
												</TextBox.FontWeight>
											</TextBox>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Expander>
					<Border
						Grid.Column="1"
						Grid.RowSpan="4"
						BorderBrush="Gray"
						BorderThickness="1"
						Background="White">
						<Viewport3D>
							<Viewport3D.Camera>
								<PerspectiveCamera Position="0,0,5"
                           LookDirection="0,0,-1"
                           UpDirection="0,1,0"
                           FieldOfView="55" />
							</Viewport3D.Camera>

							<ModelVisual3D>
								<ModelVisual3D.Content>

									<Model3DGroup>
										<Model3DGroup.Transform>
											<RotateTransform3D CenterX="0" CenterY="0" CenterZ="0">
												<RotateTransform3D.Rotation>
													<AxisAngleRotation3D x:Name="PCBRotation" Axis="0,1,0"/>
												</RotateTransform3D.Rotation>
											</RotateTransform3D>
										</Model3DGroup.Transform>
										<AmbientLight Color="White" />

										<Model3DGroup Children="{Binding PCBLayersModel}"/>

									</Model3DGroup>
								</ModelVisual3D.Content>
							</ModelVisual3D>

						</Viewport3D>
					</Border>
				</Grid>
			</TabItem>
			<TabItem Header="Order" Width="100"  >
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Text="{Binding Purchase, Mode=OneWay}"
					VerticalAlignment="Bottom"
					HorizontalAlignment="Center"/>
					<Button Grid.Row="1" Content="Confirm your request" Width="150" Height="30"
					Command="{Binding ConfirmRequestCommand}" />
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Window>
